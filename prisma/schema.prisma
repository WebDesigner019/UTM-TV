generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum StatusPermohonan {
  diterima
  dalam_semakan
  disetujui
  ditolak
  dijadualkan
  selesai
}

model Admin {
  id           Int             @id @default(autoincrement())
  nama         String
  email        String          @unique
  passwordHash String          @map("password_hash")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  histories    StatusHistory[]
  passwordResetTokens AdminPasswordResetToken[]

  @@map("admins")
}

model AdminPasswordResetToken {
  id        Int       @id @default(autoincrement())
  adminId   Int       @map("admin_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  admin     Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@map("admin_password_reset_tokens")
}

model Permohonan {
  id                   Int               @id @default(autoincrement())
  nomorRujukan         String            @unique @map("nomor_rujukan") @db.VarChar(32)
  namaInstansi         String            @map("nama_instansi")
  email                String
  noWa                 String            @map("no_wa")
  namaAcara            String            @map("nama_acara")
  tanggalAcara         DateTime          @map("tanggal_acara") @db.Date
  tempatAcara          String            @map("tempat_acara")
  filePath             String            @map("file_path")
  fileOriginalName     String            @map("file_original_name")
  fileMimeType         String            @map("file_mime_type")
  fileSizeBytes        Int               @map("file_size_bytes")
  status               StatusPermohonan  @default(diterima)
  pesanPemohon         String?           @map("pesan_pemohon") @db.Text
  catatanInternal      String?           @map("catatan_internal") @db.Text
  tokenLacak           String?           @unique @map("token_lacak")
  tokenLacakExpiresAt  DateTime?         @map("token_lacak_expires_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  statusHistory        StatusHistory[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("permohonan")
}

model StatusHistory {
  id               Int              @id @default(autoincrement())
  permohonanId     Int              @map("permohonan_id")
  statusLama       StatusPermohonan? @map("status_lama")
  statusBaru       StatusPermohonan  @map("status_baru")
  pesan            String?          @db.Text
  changedByAdminId Int?             @map("changed_by_admin_id")
  createdAt        DateTime         @default(now()) @map("created_at")
  permohonan       Permohonan       @relation(fields: [permohonanId], references: [id], onDelete: Cascade)
  admin            Admin?           @relation(fields: [changedByAdminId], references: [id], onDelete: SetNull)

  @@index([permohonanId])
  @@index([changedByAdminId])
  @@map("status_history")
}

model Pengaturan {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pengaturan")
}
